[Unit]
Description=nexcore-s-ui Service
After=network.target
Wants=network.target

[Service]
Type=simple
WorkingDirectory=/usr/local/nexcore-s-ui/
ExecStart=/usr/local/nexcore-s-ui/sui
Restart=on-failure
RestartSec=10s

# AUDIT.md H6 — systemd 加固。
#
# ⚠️ ProtectSystem=full 会把整个 /usr(包括 /usr/local)挂 RO。sui 自己的 DB
# / cert / acme 都在 /usr/local/nexcore-s-ui/ 下,必须用 ReadWritePaths 显式
# 豁免,否则 sui 写 DB 报 "attempt to write a readonly database"。
# 这是 v1.7.13 → v1.7.14 的修复点。
#
#   NoNewPrivileges        进程不能 setuid 提权(零副作用)
#   ProtectSystem=full     /usr /boot /etc 只读;ReadWritePaths 豁免 sui 工作目录
#   ProtectHome=true       /home /root /run/user 不可读,sui 不需要这些
#   PrivateTmp=true        独立 /tmp,免污染共享 tmp
#   LockPersonality        禁 personality(2) syscall
#   RestrictRealtime       禁实时调度
#   RestrictSUIDSGID       禁创建 setuid/setgid 文件
#
# 不加的(避免 break):
#   PrivateDevices         tun 入站要 /dev/net/tun
#   ProtectKernelTunables  redirect/tproxy 可能写 /proc/sys
#   User=non-root          要 bind 80/443 + ACME 写 cert,保留 root
NoNewPrivileges=true
ProtectSystem=full
ReadWritePaths=/usr/local/nexcore-s-ui
ProtectHome=true
PrivateTmp=true
LockPersonality=true
RestrictRealtime=true
RestrictSUIDSGID=true

[Install]
WantedBy=multi-user.target
